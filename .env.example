# Flask Secret Key (generate a random string for security)
SESSION_SECRET=your_random_secret_key_here

# Database Config (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/nutrition_assistant

# MongoDB Config (Optional - project will use in-memory storage if not provided)
MONGODB_URI=mongodb://username:password@localhost:27017/nutrition_assistant

# OpenAI API Key (required for chat functionality)
OPENAI_API_KEY=your_openai_api_key_here