SESSION_SECRET=your_random_secret_key_here

# MongoDB connection string
# For local development with MongoDB Compass:
# MONGODB_URI=mongodb://localhost:27017/fitmeal
#
# For MongoDB Atlas (cloud, for Render deployment):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/fitmeal?retryWrites=true&w=majority
MONGODB_URI=

# Google Gemini API key (optional — chat works without it but shows a warning)
GEMINI_API_KEY=
